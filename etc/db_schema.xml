<?xml version="1.0"?>
<!--
/**
 * RequestDesk Q&A Library - Database Schema
 *
 * requestdesk_qa_pair : the reusable Q&A pair, stored once.
 * requestdesk_qa_link : polymorphic link so one pair attaches to many entities
 *                       (blog posts, products, ...) — entity_type + entity_id.
 *
 * @category  RequestDesk
 * @package   RequestDesk_Qa
 */
-->
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="requestdesk_qa_pair" resource="default" engine="innodb" comment="RequestDesk Reusable Q&amp;A Pairs">
        <column xsi:type="int" name="qa_id" unsigned="true" nullable="false" identity="true" comment="Q&amp;A Pair ID"/>
        <column xsi:type="varchar" name="question" nullable="false" length="500" comment="Question"/>
        <column xsi:type="text" name="answer" nullable="false" comment="Answer"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="qa_id"/>
        </constraint>
        <index referenceId="REQUESTDESK_QA_PAIR_FULLTEXT" indexType="fulltext">
            <column name="question"/>
            <column name="answer"/>
        </index>
    </table>

    <table name="requestdesk_qa_link" resource="default" engine="innodb" comment="RequestDesk Q&amp;A Entity Links">
        <column xsi:type="int" name="link_id" unsigned="true" nullable="false" identity="true" comment="Link ID"/>
        <column xsi:type="int" name="qa_id" unsigned="true" nullable="false" comment="Q&amp;A Pair ID"/>
        <column xsi:type="varchar" name="entity_type" nullable="false" length="32" comment="Entity Type (blog_post, product, ...)"/>
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" comment="Entity ID within its type"/>
        <column xsi:type="int" name="position" unsigned="true" nullable="false" default="0" comment="Order within the entity"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="link_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="REQUESTDESK_QA_LINK_QA_ID_QA_PAIR_QA_ID"
                    table="requestdesk_qa_link" column="qa_id"
                    referenceTable="requestdesk_qa_pair" referenceColumn="qa_id" onDelete="CASCADE"/>
        <constraint xsi:type="unique" referenceId="REQUESTDESK_QA_LINK_QA_ENTITY_TYPE_ENTITY_ID">
            <column name="qa_id"/>
            <column name="entity_type"/>
            <column name="entity_id"/>
        </constraint>
        <index referenceId="REQUESTDESK_QA_LINK_ENTITY_TYPE_ENTITY_ID" indexType="btree">
            <column name="entity_type"/>
            <column name="entity_id"/>
        </index>
    </table>

</schema>
